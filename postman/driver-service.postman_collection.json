{
  "info": {
    "_postman_id": "5a4d8286-6adf-4dd6-b9e0-9d5bc5d5f1d1",
    "name": "Driver Service",
    "description": "Postman collection for the BITS ride-hailing Driver Service assignment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Checks whether the Driver Service is running."
      }
    },
    {
      "name": "List Drivers",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/drivers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "drivers"
          ]
        },
        "description": "Returns all drivers in the service database."
      }
    },
    {
      "name": "List Active Drivers In Bengaluru",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/drivers?is_active=true&city=Bengaluru&limit=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "drivers"
          ],
          "query": [
            {
              "key": "is_active",
              "value": "true"
            },
            {
              "key": "city",
              "value": "Bengaluru"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Used to show only active drivers that Trip Service can assign."
      }
    },
    {
      "name": "Get Driver By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/v1/drivers/{{driverId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "drivers",
            "{{driverId}}"
          ]
        },
        "description": "Fetches one driver and its status history."
      }
    },
    {
      "name": "Update Driver",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Nikhil Bose\",\n  \"phone\": \"9059702987\",\n  \"email\": \"nikhil.bose644@gmail.com\",\n  \"vehicle_type\": \"Sedan\",\n  \"vehicle_model\": \"Honda City\",\n  \"vehicle_plate\": \"TS37DZ2639\",\n  \"city\": \"Bengaluru\",\n  \"is_active\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/drivers/{{driverId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "drivers",
            "{{driverId}}"
          ]
        },
        "description": "Updates an existing driver's profile and vehicle details."
      }
    },
    {
      "name": "Create Driver",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 101,\n  \"name\": \"Amar Rao\",\n  \"phone\": \"9876543210\",\n  \"email\": \"amar.rao@example.com\",\n  \"vehicle_type\": \"SUV\",\n  \"vehicle_model\": \"Hyundai Creta\",\n  \"vehicle_plate\": \"KA01AB1234\",\n  \"city\": \"Bengaluru\",\n  \"created_at\": \"2025-07-30T05:58:56.000Z\",\n  \"is_active\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/drivers",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "drivers"
          ]
        },
        "description": "Onboards a new driver with vehicle details."
      }
    },
    {
      "name": "Update Driver Status",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"is_active\": false,\n  \"reason\": \"driver_signed_off\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/v1/drivers/{{driverId}}/status",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "v1",
            "drivers",
            "{{driverId}}",
            "status"
          ]
        },
        "description": "Marks a driver active or inactive."
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:3003"
    },
    {
      "key": "driverId",
      "value": "2"
    }
  ]
}
